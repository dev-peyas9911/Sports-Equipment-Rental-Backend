model User {
  id        String     @id @default(uuid())
  name      String     @db.VarChar(255)
  email     String     @unique
  password  String
  role      Role       @default(CUSTOMER)
  status    UserStatus @default(ACTIVE)
  phone     String    
  address   String
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@map("users")
}
